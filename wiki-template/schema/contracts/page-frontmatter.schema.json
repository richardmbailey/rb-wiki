{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rb-wiki-page-frontmatter/0.2",
  "oneOf": [
    {
      "type": "object",
      "required": ["profile"],
      "properties": {"profile": {"const": "llm-wiki-profile/0.1"}}
    },
    {"$ref": "#/$defs/profile02"}
  ],
  "$defs": {
    "profile02": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "description", "resource", "tags", "timestamp", "created", "status", "profile", "sources", "confidence", "review_state", "review_priority", "consequence_tier"],
      "properties": {
        "type": {"enum": ["Concept", "Entity", "Summary", "Synthesis", "Decision", "Contradiction", "Reference", "Dataset", "Method", "Tool", "Project", "Overview"]},
        "title": {"type": "string", "minLength": 1, "maxLength": 300},
        "description": {"type": "string", "minLength": 1, "maxLength": 1000},
        "resource": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "timestamp": {"type": "string", "format": "date-time"},
        "created": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "status": {"enum": ["active", "draft", "stale", "deprecated", "needs-review"]},
        "profile": {"const": "llm-wiki-profile/0.2"},
        "sources": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "confidence": {"enum": ["high", "medium", "low", "uncertain"]},
        "review_state": {"enum": ["pending", "in-review", "reviewed", "blocked"]},
        "review_priority": {"enum": ["normal", "high", "critical"]},
        "consequence_tier": {"enum": ["ordinary", "high-consequence"]},
        "source_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,127}$"},
        "source_type": {"enum": ["pdf", "transcript", "web", "note", "email", "dataset", "code", "audio", "video", "image", "other"]},
        "hash_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "date_published": {"type": "string"},
        "date_ingested": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "authors": {"type": "array", "items": {"type": "string"}},
        "source_access_level": {"enum": ["full-text", "raw-only", "metadata-only", "preservation-only"]},
        "derived_text": {"type": "string"},
        "extraction_status": {"type": "string"},
        "integration_state": {"enum": ["unintegrated", "partially-integrated", "integrated", "not-applicable"]},
        "assessment_state": {"enum": ["unassessed", "assessed", "needs-reassessment", "not-applicable"]},
        "validated_at": {"type": "string", "format": "date-time"}
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"const": "Reference"}}, "required": ["type"]},
          "then": {"required": ["source_id", "source_type", "hash_sha256", "date_ingested", "source_access_level", "integration_state", "assessment_state", "validated_at"]}
        }
      ]
    }
  }
}
