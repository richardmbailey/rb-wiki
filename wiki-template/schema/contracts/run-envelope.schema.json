{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rb-wiki-run-envelope/0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "run_token", "lane", "mode", "permitted_actions", "input_roots", "writable_paths", "page_types", "required_checks", "lane_contract", "consequence_tier", "expires_at", "lease_expires_at", "stop_conditions", "commit_policy", "proposal_id", "approval_id", "capabilities", "capability_digest", "agent_provenance", "artifact_handoffs"],
  "properties": {
    "schema_version": {"const": "rb-wiki-run-envelope/0.2"},
    "run_id": {"$ref": "#/$defs/runId"},
    "run_token": {"$ref": "#/$defs/runToken"},
    "lane": {"$ref": "#/$defs/lane"},
    "mode": {"$ref": "#/$defs/mode"},
    "permitted_actions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/action"}},
    "input_roots": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "writable_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "page_types": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/pageType"}},
    "required_checks": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/checkId"}},
    "lane_contract": {"$ref": "#/$defs/laneBinding"},
    "consequence_tier": {"enum": ["routine", "material", "high-consequence"]},
    "expires_at": {"type": "string", "format": "date-time"},
    "lease_expires_at": {"type": "string", "format": "date-time"},
    "stop_conditions": {"$ref": "#/$defs/stopConditions"},
    "commit_policy": {"enum": ["forbidden", "manual", "scoped-auto"]},
    "proposal_id": {"$ref": "#/$defs/nullableArtifactId"},
    "approval_id": {"$ref": "#/$defs/nullableArtifactId"},
    "capabilities": {"$ref": "#/$defs/capabilitySnapshot"},
    "capability_digest": {"$ref": "#/$defs/digest"},
    "agent_provenance": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/agentProvenance"}]},
    "artifact_handoffs": {"$ref": "#/$defs/artifactHandoffs"}
  },
  "$defs": {
    "runId": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z-[a-f0-9]{12}$"},
    "runToken": {"type": "string", "minLength": 36, "maxLength": 256, "pattern": "^run_[A-Za-z0-9_-]+$"},
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "lane": {"enum": ["maintain", "acquire", "ingest", "synthesize", "semantic", "governance"]},
    "mode": {"enum": ["manual-assist", "scheduled-propose", "authorised-autonomous-apply"]},
    "action": {"enum": ["deterministic-maintenance", "acquire-sources", "ingest-sources", "preserve-unsupported", "propose-synthesis", "edit-wiki-pages", "governance-maintenance"]},
    "pageType": {"enum": ["Concept", "Entity", "Summary", "Synthesis", "Decision", "Contradiction", "Reference", "Dataset", "Method", "Tool", "Project", "Overview"]},
    "checkId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"},
    "path": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[A-Za-z0-9._*?/-]+$"},
    "nullableArtifactId": {"type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9-]{1,127}$"},
    "laneBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "lane_id", "controller_lane", "path", "digest_sha256"],
      "properties": {
        "schema_version": {"const": "rb-wiki-lane-contract/0.2"},
        "lane_id": {"$ref": "#/$defs/checkId"},
        "controller_lane": {"$ref": "#/$defs/lane"},
        "path": {"type": "string", "pattern": "^schema/lanes/[a-z0-9-]+\\.yml$"},
        "digest_sha256": {"$ref": "#/$defs/digest"}
      }
    },
    "budgets": {
      "type": "object", "additionalProperties": false,
      "required": ["max_runtime_seconds", "max_changed_paths", "max_acquired_sources"],
      "properties": {
        "max_runtime_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "max_changed_paths": {"type": "integer", "minimum": 0, "maximum": 1000},
        "max_acquired_sources": {"type": "integer", "minimum": 0, "maximum": 10000}
      }
    },
    "stopConditions": {
      "type": "object", "additionalProperties": false,
      "required": ["budgets", "validation_failure", "authority_expiry"],
      "properties": {
        "budgets": {"$ref": "#/$defs/budgets"},
        "validation_failure": {"const": true},
        "authority_expiry": {"type": "string", "format": "date-time"}
      }
    },
    "capabilitySnapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "digest_sha256", "capabilities"],
      "properties": {
        "schema_version": {"const": "rb-wiki-capabilities/0.2"},
        "digest_sha256": {"$ref": "#/$defs/digest"},
        "capabilities": {
          "type": "object",
          "additionalProperties": {
            "type": "object", "additionalProperties": false,
            "required": ["available"],
            "properties": {
              "available": {"type": "boolean"},
              "implementation": {"type": ["string", "null"]},
              "reason": {"type": "string"},
              "alias_for": {"type": ["string", "null"]}
            }
          }
        }
      }
    },
    "agentProvenance": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "agent_label", "runtime", "provider_model", "prompt_policy_digest", "trace_reference", "started_at", "finished_at", "tool_call_summary"],
      "properties": {
        "schema_version": {"const": "rb-wiki-agent-provenance/0.2"},
        "agent_label": {"type": ["string", "null"], "maxLength": 128},
        "runtime": {"type": ["string", "null"], "maxLength": 128},
        "provider_model": {"type": ["string", "null"], "maxLength": 128},
        "prompt_policy_digest": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
        "trace_reference": {"type": ["string", "null"], "pattern": "^(?:reports|\\.wiki_state)/[A-Za-z0-9._/-]{1,240}$"},
        "started_at": {"type": ["string", "null"], "format": "date-time"},
        "finished_at": {"type": ["string", "null"], "format": "date-time"},
        "tool_call_summary": {"type": "object", "maxProperties": 32, "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 100000}}
      }
    },
    "artifactHandoffs": {
      "type": "object", "additionalProperties": false,
      "required": ["proposal", "approval"],
      "properties": {
        "proposal": {"type": ["string", "null"], "pattern": "^reports/proposals/[a-z0-9][a-z0-9-]{1,127}\\.json$"},
        "approval": {"type": ["string", "null"], "pattern": "^reports/approvals/[a-z0-9][a-z0-9-]{1,127}\\.json$"}
      }
    }
  }
}
