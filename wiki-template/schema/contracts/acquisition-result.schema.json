{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rb-wiki-acquisition-result/0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "acquisition_id", "run_id", "created_at", "agent", "query", "provider", "discovery_budget", "candidates", "selected", "selection_rationale", "preservation_state", "next_artifact"],
  "properties": {
    "schema_version": {"const": "rb-wiki-acquisition-result/0.2"},
    "acquisition_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,127}$"},
    "run_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "agent": {"$ref": "#/$defs/agent"},
    "query": {"type": "string", "minLength": 1},
    "provider": {"type": "object", "additionalProperties": false, "required": ["name", "method"], "properties": {"name": {"type": "string", "minLength": 1}, "method": {"type": "string", "minLength": 1}}},
    "discovery_budget": {"type": "object", "additionalProperties": false, "required": ["max_candidates", "max_selected"], "properties": {"max_candidates": {"type": "integer", "minimum": 1}, "max_selected": {"type": "integer", "minimum": 0}}},
    "candidates": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["candidate_id", "locator", "metadata"], "properties": {"candidate_id": {"type": "string"}, "locator": {"type": "string"}, "metadata": {"type": "object"}}}},
    "selected": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "selection_rationale": {"type": "array", "items": {"type": "string"}},
    "preservation_state": {"enum": ["not-started", "inbox-staged", "preserved", "partial", "blocked"]},
    "next_artifact": {"enum": ["source-transition", "none"]}
  },
  "$defs": {"agent": {"type": "object", "additionalProperties": false, "required": ["agent_label", "runtime_label"], "properties": {"agent_label": {"type": "string", "minLength": 1}, "runtime_label": {"type": "string", "minLength": 1}}}}
}
