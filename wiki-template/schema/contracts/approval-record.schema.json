{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rb-wiki-approval-record/0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "approval_id", "proposal_id", "proposal_run_id", "proposal_digest", "decision", "approver_label", "approver_role", "scope", "conditions", "issued_at", "expires_at", "policy_version"],
  "properties": {
    "schema_version": {"const": "rb-wiki-approval-record/0.2"},
    "approval_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,127}$"},
    "proposal_id": {"type": "string"},
    "proposal_run_id": {"type": "string"},
    "proposal_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "decision": {"enum": ["approved", "rejected"]},
    "approver_label": {"type": "string", "minLength": 1},
    "approver_role": {"type": "string", "minLength": 1},
    "scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "conditions": {"type": "array", "items": {"type": "string"}},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "policy_version": {"type": "string"}
  }
}
