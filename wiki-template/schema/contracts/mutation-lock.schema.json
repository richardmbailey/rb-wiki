{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rb-wiki-mutation-lock/0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "pid", "host", "lane", "mode", "acquired_at"],
  "properties": {
    "schema_version": {"const": "rb-wiki-mutation-lock/0.2"},
    "run_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "pid": {"type": "integer", "minimum": 1},
    "host": {"type": "string", "minLength": 1, "maxLength": 255},
    "lane": {"enum": ["maintain", "acquire", "ingest", "synthesize", "semantic", "governance"]},
    "mode": {"enum": ["manual-assist", "scheduled-propose", "authorised-autonomous-apply"]},
    "acquired_at": {"type": "string", "format": "date-time"},
    "heartbeat_at": {"type": ["string", "null"], "format": "date-time"},
    "lease_expires_at": {"type": ["string", "null"], "format": "date-time"}
  }
}
