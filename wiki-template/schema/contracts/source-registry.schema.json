{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rb-wiki-source-registry/0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": {"const": "rb-wiki-source-registry/0.2"},
    "sources": {
      "type": "array",
      "items": {"$ref": "#/$defs/source"}
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "raw_path", "reference_path", "hash_sha256", "source_type", "date_ingested", "date_published", "status", "ingest_state", "access_level", "processed_path", "derivative_path"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,127}$"},
        "raw_path": {"type": "string", "pattern": "^sources/raw/[A-Za-z0-9._-]+$"},
        "reference_path": {"type": "string", "pattern": "^wiki/references/[A-Za-z0-9._-]+\\.md$"},
        "hash_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_type": {"enum": ["pdf", "transcript", "web", "note", "email", "dataset", "code", "audio", "video", "image", "other"]},
        "date_ingested": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "date_published": {"type": "string", "minLength": 1},
        "status": {"enum": ["active", "superseded", "rejected", "needs-review"]},
        "ingest_state": {"enum": ["captured", "raw-preserved", "registered", "reference-created", "validated", "inbox-archived", "recovery-required"]},
        "access_level": {"enum": ["full-text", "raw-only", "metadata-only", "preservation-only"]},
        "processed_path": {"type": ["string", "null"], "pattern": "^inbox/processed/[0-9]{4}-[0-9]{2}-[0-9]{2}/[A-Za-z0-9][A-Za-z0-9._ -]{0,199}$"},
        "derivative_path": {"type": ["string", "null"], "pattern": "^sources/derived/[A-Za-z0-9._-]+$"}
      }
    }
  }
}
